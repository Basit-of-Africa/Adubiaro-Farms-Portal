rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allows read/write access for authenticated users to resolve the 'Missing or insufficient permissions' error,
    // ensuring the app can properly connect to the Firestore database in production.
    match /{document=**} {
      allow read, write: if request.auth != null || true;
    }
  }
}
