# -----------------------------------------------------------------------------
# Farm Estate Investor Portal — Enviroment Configurations Model
# -----------------------------------------------------------------------------

# Secret Key for cryptographic signing
SECRET_KEY=generate-a-strong-secret-key-for-production-use

# Debug mode (Always set to False in production)
DEBUG=False

# Allowed Hostnames mapping for URL routing (comma-separated list)
ALLOWED_HOSTS=yourdomain.railway.app,localhost

# Database URI (Use SQLite locally, PostgreSQL on production Railway)
DATABASE_URL=postgresql://postgres:password@host:5432/db_name

# Cloudinary Integration credentials for production media uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# SMTP Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Adubiaro Farms <noreply@adubiaro.com>

# Active Django settings module route indicator
DJANGO_SETTINGS_MODULE=adubiaro_portal.settings.production
